# ─── Wallet ────────────────────────────────────────────────────────────────────
# Deployer / owner private key (without 0x prefix)
PRIVATE_KEY=your_wallet_private_key

# ─── RPC URLs ──────────────────────────────────────────────────────────────────
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# ─── Agent ─────────────────────────────────────────────────────────────────────
# The ARIA backend wallet address granted reallocate() rights
AGENT_ADDRESS=your_agent_wallet_address

# ─── Fee Recipient ─────────────────────────────────────────────────────────────
# Treasury wallet that receives management and performance fees.
# Set to 0x0000000000000000000000000000000000000000 to disable fee collection.
FEE_RECIPIENT_ADDRESS=your_treasury_wallet_address

# ─── Block Explorer API Key (optional) ─────────────────────────────────────────
# Mantle Explorer does not require an API key — leave blank or set "no-api-key"
MANTLE_EXPLORER_API_KEY=no-api-key

# ─── Gas Reporting (optional) ──────────────────────────────────────────────────
# Set to "true" to print gas usage after tests
REPORT_GAS=false
