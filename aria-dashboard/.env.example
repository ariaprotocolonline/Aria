# ═══════════════════════════════════════════════════════════════════
#  ARIA Dashboard — Environment Variables
#  Copy this file to .env and fill in the values.
#  All variables must be prefixed with VITE_ so Vite exposes them
#  to the browser bundle at build time.
# ═══════════════════════════════════════════════════════════════════

# ── Anthropic ────────────────────────────────────────────────────────────────
# SECURITY: Do NOT set VITE_ANTHROPIC_API_KEY — it is intentionally absent from
# env.ts and is NOT read by the dashboard. All Claude calls are proxied through
# aria-server so the key never ships in the browser bundle. Set ANTHROPIC_API_KEY
# in the root .env (server-side only) and VITE_API_URL below to point at aria-server.
# VITE_ANTHROPIC_API_KEY=  ← leave commented out — DO NOT SET

# Claude model to use across the entire dashboard (feed, chat, agent memory).
# Default: claude-sonnet-4-6
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6

# Anthropic API version header. Change only if Anthropic releases a new version.
# Default: 2023-06-01
VITE_ANTHROPIC_VERSION=2023-06-01

# Base URL for the Anthropic messages endpoint.
# Override this to point at your own proxy server in production.
# Default: https://api.anthropic.com/v1/messages
VITE_ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# ── WalletConnect ────────────────────────────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
# Required for WalletConnect v2 support (MetaMask mobile, Ledger, etc.)
VITE_WALLETCONNECT_PROJECT_ID=

# ── ARIAVault Contract Addresses ─────────────────────────────────────────────
# Fill these in after running the deploy scripts in aria-contracts/.
#   Testnet:  cd aria-contracts && npx hardhat run scripts/deploy.ts --network mantleTestnet
#   Mainnet:  cd aria-contracts && npx hardhat run scripts/deploy.ts --network mantleMainnet
VITE_VAULT_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
VITE_FACTORY_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_FACTORY_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# ── Token Addresses ───────────────────────────────────────────────────────────
# Mainnet: official Mantle protocol addresses — update only if they change.
VITE_USDY_ADDRESS_MAINNET=0x5bE26527e817998A7206475496fDE1E68957c5A6
VITE_METH_ADDRESS_MAINNET=0xcDA86A272531e8640cD7F1a92c01839911B90bb0

# Testnet: deploy mock ERC-20 contracts and paste the addresses here.
#   cd aria-contracts && npx hardhat run scripts/deployMocks.ts --network mantleTestnet
VITE_USDY_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_METH_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000

# ── RPC URLs ─────────────────────────────────────────────────────────────────
# Override to use a private RPC (Alchemy, Infura, QuickNode) for higher limits.
# Defaults use the public Mantle endpoints.
VITE_MANTLE_RPC_URL=https://rpc.mantle.xyz
VITE_MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz

# ── Block Explorer URLs ───────────────────────────────────────────────────────
VITE_MANTLE_EXPLORER_URL=https://explorer.mantle.xyz
VITE_MANTLE_TESTNET_EXPLORER_URL=https://explorer.sepolia.mantle.xyz

# ── Proxy server (aria-server) — REQUIRED for production ─────────────────────
# All Claude API calls are routed through this to enforce rate limits.
# Set to the public URL where aria-server is reachable.
VITE_API_URL=http://localhost:3002

# ── Agent feed server (aria-agent) ───────────────────────────────────────────
# Set to http://localhost:3001 in development, or your VPS address in production.
VITE_FEED_URL=http://localhost:3001

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=ARIA
