# ═══════════════════════════════════════════════════════════════════════════════
#  ARIA — Master Environment File
#
#  This single file covers all three sub-projects:
#    • aria-dashboard  (Vite frontend — variables must be prefixed VITE_)
#    • aria-contracts  (Hardhat deploy & verify scripts)
#    • aria-agent      (Node.js backend agent)
#
#  Usage:
#    cp .env.example .env
#    Fill in every blank value, then run whichever sub-project you need.
#
#  Security:
#    • Never commit .env to git — it is in .gitignore at this root.
#    • VITE_ variables are embedded in the browser bundle. Do NOT put private
#      keys or deployer secrets in VITE_ variables.
#    • Keep deployer/agent private keys only in the non-VITE_ variables below.
# ═══════════════════════════════════════════════════════════════════════════════


# ── DeepSeek (primary AI) ─────────────────────────────────────────────────────
# Used by: aria-agent (decision engine), aria-server (chat proxy)
# DeepSeek is tried first. If the key is absent or the call fails, Claude is used.
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


# ── Anthropic (fallback AI) ───────────────────────────────────────────────────
# Used by: aria-dashboard (chat/feed), aria-agent (explainer)
#
# ⚠️  VITE_ANTHROPIC_API_KEY is exposed client-side (browser bundle).
#     For production, remove it and route dashboard Claude calls through a
#     backend proxy so the key never leaves the server.
#
VITE_ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=

# Claude model — shared default across dashboard and agent.
# Current production model: claude-sonnet-4-6
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6

# Anthropic API version header (change only when Anthropic releases a new one).
VITE_ANTHROPIC_VERSION=2023-06-01

# Anthropic messages endpoint. Override to point at your own proxy in production.
VITE_ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages


# ── WalletConnect ─────────────────────────────────────────────────────────────
# Used by: aria-dashboard
# Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=


# ── Deployer Wallet ───────────────────────────────────────────────────────────
# Used by: aria-contracts (deploy & verify scripts)
# ⚠️  Never prefix this with VITE_ — must stay server-side only.
# Private key of the wallet that owns the ARIAVault contract (no 0x prefix).
PRIVATE_KEY=


# ── Agent Wallet ──────────────────────────────────────────────────────────────
# Used by: aria-contracts (deploy — sets initial agent address)
#          aria-agent     (signs reallocate() transactions)
# ⚠️  Never prefix this with VITE_ — must stay server-side only.
AGENT_PRIVATE_KEY=
AGENT_ADDRESS=


# ── Fee Recipient ─────────────────────────────────────────────────────────────
# Used by: aria-contracts (deploy — receives performance + management fees)
#
# ⚠️  MUST be a dedicated cold-storage treasury wallet.
#     MUST NOT be the same address as AGENT_ADDRESS.
#     If they are the same, the deploy scripts will reject it.
#
# The agent wallet (AGENT_ADDRESS) is a hot wallet exposed to the network.
# Fees that accumulate there are at risk if the agent key is ever compromised.
# Use a hardware wallet or a separate cold wallet for FEE_RECIPIENT_ADDRESS.
#
# Set to zero address to disable fee collection entirely.
FEE_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000


# ── ARIAVault Contract Addresses ──────────────────────────────────────────────
# Used by: aria-dashboard (contract reads/writes), aria-agent (reallocate calls)
# Fill these in after running the deploy scripts:
#   Testnet:  cd aria-contracts && npx hardhat run scripts/deploy.ts --network mantleTestnet
#   Mainnet:  cd aria-contracts && npx hardhat run scripts/deploy.ts --network mantleMainnet
#
# FACTORY_ADDRESS (preferred) — the agent reads all user vaults from the factory.
# VAULT_ADDRESS — single-vault fallback used only when FACTORY_ADDRESS is absent.
# Both are auto-patched by the deploy script.
#
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_FACTORY_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
VITE_FACTORY_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
VAULT_ADDRESS=0x0000000000000000000000000000000000000000


# ── Token Addresses ───────────────────────────────────────────────────────────
# Used by: aria-dashboard (deposit/withdraw token approval)
#
# Mainnet — official Mantle protocol addresses (stable, update only if they change)
VITE_WETH_ADDRESS_MAINNET=0xdEAddEaDdeadDEadDEADDEaDDeaDDeAD00000000
VITE_USDC_ADDRESS_MAINNET=0x09bc4e0d864854c6afb6eb9a9cdf58ac190d0df9
#
# Testnet — deploy mock ERC-20s and paste addresses here:
#   cd aria-contracts && npx hardhat run scripts/deployMocks.ts --network mantleTestnet
VITE_WETH_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VITE_USDC_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000


# ── RPC URLs ──────────────────────────────────────────────────────────────────
# Used by: aria-dashboard (wagmi), aria-contracts (Hardhat network), aria-agent (viem)
# Override with a private RPC (Alchemy, Infura, QuickNode) for higher rate limits.
#
VITE_MANTLE_RPC_URL=https://rpc.mantle.xyz
VITE_MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_RPC=https://rpc.mantle.xyz


# ── Block Explorer URLs ───────────────────────────────────────────────────────
# Used by: aria-dashboard (transaction links), aria-contracts (verify)
VITE_MANTLE_EXPLORER_URL=https://explorer.mantle.xyz
VITE_MANTLE_TESTNET_EXPLORER_URL=https://explorer.sepolia.mantle.xyz
MANTLE_EXPLORER_API_KEY=no-api-key


# ── API / Feed URLs ───────────────────────────────────────────────────────────
# Used by: aria-dashboard (Vite build embeds these values — must be correct BEFORE building)
#
# ⚠️  In production these must point to your public domain, NOT localhost.
#     Local dev uses Vite proxy (/api → 3002, /feed → 3001) so set these to
#     empty for dev and fill them for production builds.
#
VITE_API_URL=https://ariaprotocol.online
VITE_FEED_URL=https://ariaprotocol.online/feed

# Port aria-server listens on (PM2 reads this)
SERVER_PORT=3002


# ── Server auth ───────────────────────────────────────────────────────────────
# Used by: aria-server (HMAC session tokens)
# MUST be set to a stable 32-byte hex string. If unset, all sessions are
# invalidated on every PM2 restart.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=


# ── CORS ──────────────────────────────────────────────────────────────────────
# Used by: aria-server (Express CORS middleware)
# Comma-separated list of allowed origins in production. Localhost origins are
# automatically added in development (NODE_ENV !== 'production') only.
ALLOWED_ORIGINS=https://ariaprotocol.online,https://www.ariaprotocol.online


# ── Agent Runtime ─────────────────────────────────────────────────────────────
# Used by: aria-agent
# How often the agent runs its yield-scanning cycle (milliseconds).
CYCLE_INTERVAL_MS=300000
# Risk profile the agent operates under: Conservative | Balanced | Aggressive
RISK_PROFILE=Balanced


# ── App ───────────────────────────────────────────────────────────────────────
# Used by: aria-dashboard
VITE_APP_NAME=ARIA


# ── Gas Reporting ─────────────────────────────────────────────────────────────
# Used by: aria-contracts (test suite)
# Set to true to print gas usage table after running tests.
REPORT_GAS=false


# ── xStocks ───────────────────────────────────────────────────────────────────
# Set to true once xStock contract addresses are verified on explorer.mantle.xyz
# When false, the agent never references xStocks in its Claude analysis prompts.
XSTOCKS_ENABLED=false


# ── Elfa AI ───────────────────────────────────────────────────────────────────
# Real-time onchain social signals and smart money activity.
# Optional — agent runs without it, Elfa section in Claude prompt will show
# "No Elfa signal data available" until a key is provided.
# Get your key at: https://elfa.ai
ELFA_API_KEY=

# ── Nansen ────────────────────────────────────────────────────────────────────
# Smart money wallet tracking and pool-level mercenary capital detection.
# Optional — liquidity scores fall back to onchain-only when key is absent.
# Get your key at: https://nansen.ai
NANSEN_API_KEY=


# ── Telegram ──────────────────────────────────────────────────────────────────
# Real-time notifications and chat via @AriaRWAbot
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AriaRWAbot
TELEGRAM_WEBHOOK_URL=https://api.ariaprotocol.online/telegram/webhook
# Random secret passed to Telegram's setWebhook. Telegram sends it back on every
# webhook POST as X-Telegram-Bot-Api-Secret-Token. Requests without it are rejected.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Address of the vault owner — used by the agent to send Telegram notifications
VAULT_OWNER_ADDRESS=0xYourDeployerWalletAddress

# Shared secret between aria-agent and aria-server for /internal/notify
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=change-this-to-a-random-string

# aria-server base URL — used by aria-tgbot and aria-agent to reach aria-server.
# MUST be a loopback address (127.0.0.1) in ALL environments — tgbot and agent are
# always co-located with the server. Never set to the public domain here.
ARIA_SERVER_URL=http://127.0.0.1:3002
